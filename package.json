{
  "name": "daily-scrum",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon --watch server/src --exec 'node -r dotenv/config server/src/index.js'",
    "dev:client": "npm --prefix client run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
